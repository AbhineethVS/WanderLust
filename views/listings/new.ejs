<% layout("/layouts/boilerplate")%>
<div class="row">
	<div class="col-8 offset-2">
		<body>
			<br /><br /><br />
			<h3>Create New Listing</h3>
			<form
				action="/listings"
				method="post"
				novalidate
				class="needs-validation"
			>
				<div>
					<label for="title" class="form-label">Title</label>
					<input
						type="text"
						name="listing[title]"
						class="form-control"
						placeholder="Enter Title"
						required
					/>
					<div class="valid-feedback">Title looks good!</div>
					<div class="invalid-feedback">
						Please enter a valid title
					</div>
				</div>

				<br /><br />
				<div>
					<label for="description" class="form-label"
						>Description</label
					>
					<textarea
						class="form-control"
						type="text"
						name="listing[description]"
						placeholder="Enter Description"
						required
					></textarea>
					<div class="valid-feedback">Description looks good!</div>
					<div class="invalid-feedback">
						Please enter a short description
					</div>
				</div>

				<br /><br />
				<div>
					<label for="image" class="form-label">Image URL</label>
					<input
						class="form-control"
						type="text"
						name="listing[image]"
						placeholder="Enter image URL/Link"
					/>
				</div>

				<br /><br />
				<div class="row">
					<div class="mb-3 col-md-4">
						<label for="price" class="form-label">Price</label>
						<input
							class="form-control"
							type="number"
							name="listing[price]"
							placeholder="1200"
							required
						/>
						<div class="valid-feedback">Price looks good!</div>
						<div class="invalid-feedback">
							Please enter a valid price
						</div>
					</div>

					<br /><br />
					<div class="mb-3 col-md-8">
						<label for="country" class="form-label">Country</label>
						<input
							type="text"
							name="listing[country]"
							placeholder="India"
							class="form-control"
							required
						/>
						<div class="valid-feedback">
							Country name looks good!
						</div>
						<div class="invalid-feedback">
							Please enter a valid country name
						</div>
					</div>
				</div>

				<br /><br />
				<div>
					<label for="location" class="form-label">Location</label>
					<input
						type="text"
						name="listing[location]"
						placeholder="Banglore, Karnataka"
						class="form-control"
						required
					/>
					<div class="valid-feedback">Location looks good!</div>
					<div class="invalid-feedback">
						Please enter a valid location
					</div>
				</div>

				<br /><br />
				<button class="btn btn-dark add-btn">Add</button>
				<br /><br /><br />
			</form>
		</body>
	</div>
</div>
